# ============================================================
# Aegis SaaS Backend — Environment Variables
# ============================================================
# Salin file ini menjadi .env (sudah di-gitignore), lalu isi.
# Untuk demo cepat: register sandbox di https://dashboard.sandbox.midtrans.com

# ----- Server -----
PORT=3000

# ----- Midtrans (Indonesia payment gateway) -----
# Mode demo/kompetisi: PRODUCTION=false (sandbox)
MIDTRANS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_FINISH_URL=http://localhost:3000/success

# ----- AI Backend (untuk dipakai openclaw/_shared/ai/) -----
# Akan dipakai saat Phase AI Backend dieksekusi
AEGIS_AI_BACKEND=mock
GROQ_API_KEY=
AEGIS_AI_MODEL=llama-3.3-70b-versatile
