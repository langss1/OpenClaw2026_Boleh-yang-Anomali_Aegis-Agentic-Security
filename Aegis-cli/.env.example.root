# ============================================================
# Aegis SaaS Backend - Environment Variables
# ============================================================
# Salin file ini menjadi .env (sudah di-gitignore), lalu isi.
# Untuk demo cepat: register sandbox di
#   https://dashboard.sandbox.midtrans.com
# Lalu Settings -> Access Keys -> copy Server Key dan Client Key.

# ----- Server -----
PORT=3000
# Bind address. Untuk VPS: gunakan 0.0.0.0 agar bisa diakses dari luar.
HOST=0.0.0.0
# URL publik yang dipakai untuk callback / finish_url Midtrans di VPS.
# Contoh: https://aegis.contoh.com
AEGIS_PUBLIC_URL=http://localhost:3000

# ----- Midtrans (Indonesia payment gateway) -----
# Untuk demo/kompetisi: MIDTRANS_PRODUCTION=false (sandbox)
MIDTRANS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
# Jika kosong, fallback ke ${AEGIS_PUBLIC_URL}/success
MIDTRANS_FINISH_URL=

# ============================================================
# VPS Integration (digunakan oleh script deploy/, opsional)
# ============================================================
# Hostname / IP VPS Anda
VPS_HOST=
# User SSH (umumnya 'root' atau 'ubuntu')
VPS_USER=root
# Port SSH (default 22)
VPS_PORT=22
# Path absolut tempat aplikasi akan dideploy di VPS
VPS_APP_DIR=/opt/aegis
# Nama service systemd (jika deploy tanpa Docker)
VPS_SERVICE_NAME=aegis
# Domain publik (untuk konfigurasi nginx + Let's Encrypt). Kosongkan jika cuma pakai IP.
VPS_DOMAIN=
VPS_LETSENCRYPT_EMAIL=

# ============================================================
# OpenClaw Agent runtime (opsional)
# ============================================================
# Backend AI untuk agent Pentest/QA: deepseek | openai | ollama | mock
AEGIS_AI_BACKEND=mock
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Endpoint QA Aegis untuk error routing dari agent Pentest
QA_AEGIS_ENABLED=true
QA_AEGIS_ENDPOINT=http://localhost:9090/qa-aegis/intake
