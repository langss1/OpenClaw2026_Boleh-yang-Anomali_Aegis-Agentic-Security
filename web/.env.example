# Next.js (web/) — port default 3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Proxy /api/* ke server SaaS (server/) — port default 4000
API_URL=http://localhost:4000

# Supabase Auth (wajib untuk login email/GitHub production)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev: lewati redirect auth ketat
# SKIP_AUTH=true

# Dev: tombol di /pricing dan /login (butuh DEV_PAYMENT_SIM di .env root)
NEXT_PUBLIC_DEV_PAYMENT_SIM=true
NEXT_PUBLIC_DEV_AUTH_SIM=true
