# ============================================================
# Aegis monorepo — Environment Variables
# ============================================================

# ----- API server (Express, server/) -----
PORT=4000
HOST=0.0.0.0

# ----- Web marketing (Next.js, web/) — port 3000 -----
AEGIS_WEB_URL=http://localhost:3000
AEGIS_PUBLIC_URL=http://localhost:3000

# ----- Midtrans -----
MIDTRANS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_FINISH_URL=
MIDTRANS_ERROR_URL=
DEV_PAYMENT_SIM=true

# ----- VPS (deploy/) -----
VPS_HOST=
VPS_USER=root
VPS_PORT=22
VPS_APP_DIR=/opt/aegis
VPS_SERVICE_NAME=aegis
VPS_DOMAIN=
VPS_LETSENCRYPT_EMAIL=

# ----- OpenClaw agents -----
AEGIS_AI_BACKEND=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
QA_AEGIS_ENABLED=true
QA_AEGIS_ENDPOINT=http://localhost:9090/qa-aegis/intake

# ----- Legacy dashboard app (src/ di root, dari teman) — opsional -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VERCEL_TOKEN=

# ----- Supabase (salin ke web/.env.local) -----
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# API_URL=http://localhost:4000
