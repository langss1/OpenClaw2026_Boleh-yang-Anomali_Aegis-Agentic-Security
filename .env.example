# ============================================================
# Aegis SaaS — Environment Variables
# ============================================================
# Salin ke .env (gitignored). Sandbox Midtrans:
#   https://dashboard.sandbox.midtrans.com

# ----- API server (Express, server/) -----
PORT=4000
HOST=0.0.0.0

# ----- Web marketing (Next.js, web/) — port 3000 -----
AEGIS_WEB_URL=http://localhost:3000
# Alias untuk script deploy VPS (callback Midtrans)
AEGIS_PUBLIC_URL=http://localhost:3000

# ----- Midtrans -----
MIDTRANS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
# Kosong = pakai AEGIS_WEB_URL/success dan .../pricing?payment=cancelled
MIDTRANS_FINISH_URL=
MIDTRANS_ERROR_URL=

# ----- Dev (lokal) -----
DEV_PAYMENT_SIM=true

# ============================================================
# VPS Integration (deploy/, opsional)
# ============================================================
VPS_HOST=
VPS_USER=root
VPS_PORT=22
VPS_APP_DIR=/opt/aegis
VPS_SERVICE_NAME=aegis
VPS_DOMAIN=
VPS_LETSENCRYPT_EMAIL=

# ============================================================
# OpenClaw agents (opsional)
# ============================================================
AEGIS_AI_BACKEND=mock
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
QA_AEGIS_ENABLED=true
QA_AEGIS_ENDPOINT=http://localhost:9090/qa-aegis/intake

# ----- Next.js web/ (salin ke web/.env.local) -----
# NEXT_PUBLIC_DEV_AUTH_SIM=true
# NEXT_PUBLIC_DEV_PAYMENT_SIM=true
# API_URL=http://localhost:4000
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
