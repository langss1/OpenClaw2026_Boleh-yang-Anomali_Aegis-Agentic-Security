# Next.js (web/) — port default 3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Proxy /api/* ke server SaaS (server/) — port default 4000
API_URL=http://localhost:4000

# Supabase auth (opsional; tanpa ini middleware auth dilewati)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev: lewati redirect auth
# SKIP_AUTH=true

# Dev: tombol "Simulasi bayar" di /pricing (butuh DEV_PAYMENT_SIM=true di .env root)
NEXT_PUBLIC_DEV_PAYMENT_SIM=true

# Dev: tombol "Masuk sebagai Dev" di /login (tanpa Supabase)
NEXT_PUBLIC_DEV_AUTH_SIM=true
